# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://stockai:stockai@postgres:5432/stockai

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/2

# ── Auth ──────────────────────────────────────────────────────
# 로컬 개발용 임의 문자열로 교체 (예: openssl rand -hex 32)
SECRET_KEY=change-me-before-running

# ── Service URLs ──────────────────────────────────────────────
ML_SERVICE_URL=http://ml:8001

# ── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_ML_URL=http://localhost/ml
NEXT_PUBLIC_WS_URL=ws://localhost

# ── Production only (RDS) ─────────────────────────────────────
# RDS_URL=postgresql://user:password@your-rds-endpoint:5432/stockai
# EC2_HOST=your-ec2-ip-or-domain
